{
  "interface_version": 2,
  "name": "MaaNTEActivityAutoOnhook",
  "description": "这是一个使用 MaaFramework 创建的新项目。11",
  "contact": "QQ群: 123456789",
  "license": "MIT",
  "welcome": "首次使用！欢迎使用 MAA!",
  "github": "https://github.com/Shamikoyuko/NTEActivityAutoOnhook",
  "version": "v1.0.5",
  "controller": [
    {
      "name": "Win32",
      "label": "默认控制",
      "type": "Win32",
      "permission_required": true,
      "win32": {
        "class_regex": "UnrealWindow",
        "window_regex": "^\\s*(异环|NTE)\\s*$",
        "screencap": "Background",
        "mouse": "SendMessageWithCursorPos",
        "keyboard": "PostMessage"
      }
    },
    {
      "name": "Win32-Front",
      "label": "前台控制",
      "type": "Win32",
      "win32": {
        "class_regex": "UnrealWindow",
        "window_regex": "^\\s*(异环|NTE)\\s*$",
        "screencap": "PrintWindow",
        "mouse": "Seize",
        "keyboard": "Seize"
      }
    },
    {
      "name": "Win32-Background",
      "label": "后台控制",
      "type": "Win32",
      "permission_required": true,
      "win32": {
        "class_regex": "UnrealWindow",
        "window_regex": "^\\s*(异环|NTE)\\s*$",
        "screencap": "PrintWindow",
        "mouse": "SendMessageWithWindowPos",
        "keyboard": "PostMessage"
      }
    }
  ],
  "resource": [
    {
      "name": "官服",
      "label": "官服资源包",
      "path": [
        "resource"
      ]
    }
  ],
  "agent": {
    "child_exec": "python",
    "child_args": [
      "agent/main.py"
    ]
  },
  "group": [],
  "task": [
    {
      "name": "开始黑暗赛车界",
      "entry": "开始黑暗赛车界"
    }
  ],
  "import": [],
  "option": {}
}