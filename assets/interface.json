{
    // 本文件主要定义了通用 UI 的行为和显示内容
    // 可参考文档和示例添加更多您需要的功能
    // 文档：https://maafw.xyz/docs/3.3-ProjectInterfaceV2
    // 示例：https://github.com/MaaXYZ/MaaFramework/blob/main/sample/interface.json
    "interface_version": 2,
    "name": "MaaNTEActivityAutoOnhook",
    "description": "这是一个使用 MaaFramework 创建的新项目。",
    "contact": "QQ群: 123456789",
    "license": "MIT",
    "welcome": "首次使用！欢迎使用 MAA!",
    // 填写项目地址和版本号可实现自动更新功能
    "github": "https://github.com/Shamikoyuko/NTEActivityAutoOnhook",
    "version": "1.0.0",
    // Mirror酱为第三方分发服务，新项目默认关闭
    // 若有需要请联系 Mirror酱 开通，直接自行开启是无法使用的
    // "mirrorchyan_rid": "MaaXXX",
    // "mirrorchyan_multiplatform": true,
    "controller": [
        {
            "name": "Win32",
            "label": "默认控制",
            "type": "Win32",
            "permission_required": true,
            "win32": {
                "class_regex": "UnrealWindow",
                "window_regex": "^\\s*(异环|NTE)\\s*$",
                "screencap": "Background",
                "mouse": "SendMessageWithCursorPos",
                "keyboard": "PostMessage"
            }
        },
        {
            "name": "Win32-Front",
            "label": "前台控制",
            "type": "Win32",
            "win32": {
                "class_regex": "UnrealWindow",
                "window_regex": "^\\s*(异环|NTE)\\s*$",
                "screencap": "PrintWindow",
                "mouse": "Seize",
                "keyboard": "Seize"
            }
        },
        {
            "name": "Win32-Background",
            "label": "后台控制",
            "type": "Win32",
            "permission_required": true,
            "win32": {
                "class_regex": "UnrealWindow",
                "window_regex": "^\\s*(异环|NTE)\\s*$",
                "screencap": "PrintWindow",
                "mouse": "SendMessageWithWindowPos",
                "keyboard": "PostMessage"
            }
        }
    ],
    "resource": [
        {
            "name": "官服",
            "label": "官服资源包",
            "path": [
                "resource/base"
            ]
        }
    ],
    "agent": {
        "child_exec": "python",
        "child_args": [
            "../agent/main.py"
        ]
    },
    "group": [
        {}
    ],
    "task": [{
        "name": "开始黑暗赛车界",
        "entry": "开始黑暗赛车界"
    }],
    "import": [],
    "option": {}
}